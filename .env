# رابط Vendure API الخاص بك
VENDURE_SHOP_API_URL=https://bramjlive.com/shop-api

# Channel Token (ابقيه default أو غيره لو عندك channel مخصص)
VENDURE_CHANNEL_TOKEN=__default_channel__

# رابط الموقع النهائي
NEXT_PUBLIC_SITE_URL=https://pandastore.bramjlive.com

# اسم المتجر
NEXT_PUBLIC_SITE_NAME=Panda Store

# مفتاح عشوائي للـ Cache (ضروري!)
REVALIDATION_SECRET=اكتب_هنا_مفتاح_عشوائي_طويل
